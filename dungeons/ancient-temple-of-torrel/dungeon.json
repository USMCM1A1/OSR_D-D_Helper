      "rooms": [
        {
          "id": "R01",
          "name": "R01 The Scorched Threshold",
          "state": "unexplored",
          "tags": [
            "special",
            "stairs_up"
          ],
          "reaction_required": false,
          "notes": "The whirlwind is a residual elemental effect left by the Djinn's passage. Not dangerous. It drifts slowly toward the deeper levels \u2014 a subtle compass pointing downward. If players speak to it or cast magic near it, it spins faster briefly then resumes. Cannot be dispersed by mundane means. DC 12 Arcana or Religion reveals this is a trace manifestation of a powerful air elemental presence. The burn pattern on the threshold is roughly humanoid, approximately 12 feet tall. The missing doors were not broken \u2014 they were vaporized or taken. This room should generate questions the dungeon will not immediately answer.",
          "encounter_ref": null,
          "treasure_tier": null,
          "box_text": "The entrance yawns open where stone doors once stood \u2014 they are gone, not broken, simply gone. The threshold is blackened in a shape that radiates outward like a sunburst, still faintly warm to the touch. Sand drifts in from outside but stops at the burn line, as if unwilling to cross. At the center of the room, a miniature whirlwind of fine golden sand spins slowly, knee-high, without any apparent source.\r\n",
          "encounter_text": "",
          "treasure_text": "",
          "special_text": "",
          "statblocks": "",
          "image_region": {
            "kind": "polygon",
            "points": [
